@page "/operationtypes/edit"
@using Microsoft.EntityFrameworkCore
@using LiteTe.Data
@inject IDbContextFactory<LiteTe.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>OperationType</h2>
<hr />
@if (OperationType is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="OperationType" OnValidSubmit="UpdateOperationType" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="OperationType.OperationTypeId" value="@OperationType.OperationTypeId" />
                <div class="mb-3">
                    <label for="operationtypename" class="form-label">OperationTypeName:</label>
                    <InputText id="operationtypename" @bind-Value="OperationType.OperationTypeName" class="form-control" />
                    <ValidationMessage For="() => OperationType.OperationTypeName" class="text-danger" />
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/operationtypes">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int OperationTypeId { get; set; }

    [SupplyParameterFromForm]
    private OperationType? OperationType { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        OperationType ??= await context.OperationTypes.FirstOrDefaultAsync(m => m.OperationTypeId == OperationTypeId);

        if (OperationType is null)
        {
            NavigationManager.NotFound();
        }
    }

    // To protect from overposting attacks, enable the specific properties you want to bind to.
    // For more information, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task UpdateOperationType()
    {
        using var context = DbFactory.CreateDbContext();
        context.Attach(OperationType!).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!OperationTypeExists(OperationType!.OperationTypeId))
            {
                NavigationManager.NotFound();
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/operationtypes");
    }

    private bool OperationTypeExists(int operationtypeid)
    {
        using var context = DbFactory.CreateDbContext();
        return context.OperationTypes.Any(e => e.OperationTypeId == operationtypeid);
    }
}
