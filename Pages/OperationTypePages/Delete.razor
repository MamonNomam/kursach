@page "/operationtypes/delete"
@using Microsoft.EntityFrameworkCore
@using LiteTe.Data
@inject IDbContextFactory<LiteTe.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>OperationType</h2>
    <hr />
    @if (operationtype is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">OperationTypeName</dt>
            <dd class="col-sm-10">@operationtype.OperationTypeName</dd>
        </dl>
        <EditForm method="post" Model="operationtype" OnValidSubmit="DeleteOperationType" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(operationtype is null)">Delete</button> |
            <a href="/operationtypes">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private OperationType? operationtype;

    [SupplyParameterFromQuery]
    private int OperationTypeId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        operationtype = await context.OperationTypes.FirstOrDefaultAsync(m => m.OperationTypeId == OperationTypeId);

        if (operationtype is null)
        {
            NavigationManager.NotFound();
        }
    }

    private async Task DeleteOperationType()
    {
        using var context = DbFactory.CreateDbContext();
        context.OperationTypes.Remove(operationtype!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/operationtypes");
    }
}
