@page "/stocks/details"
@using Microsoft.EntityFrameworkCore
@using LiteTe.Data
@inject IDbContextFactory<LiteTe.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h2>Stock</h2>
    <hr />
    @if (stock is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">ProductId</dt>
            <dd class="col-sm-10">@stock.ProductId</dd>
            <dt class="col-sm-2">Count</dt>
            <dd class="col-sm-10">@stock.Count</dd>
        </dl>
        <div>
            <a href="@($"/stocks/edit?stockid={stock.StockId}")">Edit</a> |
            <a href="@($"/stocks")">Back to List</a>
        </div>
    }
</div>

@code {
    private Stock? stock;

    [SupplyParameterFromQuery]
    private int StockId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        stock = await context.Stocks.FirstOrDefaultAsync(m => m.StockId == StockId);

        if (stock is null)
        {
            NavigationManager.NotFound();
        }
    }
}
