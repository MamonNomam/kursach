@page "/stocks/create"
@using Microsoft.EntityFrameworkCore
@using LiteTe.Data
@inject IDbContextFactory<LiteTe.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create</PageTitle>

<h1>Create</h1>

<h2>Stock</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="Stock" OnValidSubmit="AddStock" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert"/>
            <div class="mb-3">
                <label for="productid" class="form-label">ProductId:</label> 
                <InputNumber id="productid" @bind-Value="Stock.ProductId" class="form-control" /> 
                <ValidationMessage For="() => Stock.ProductId" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="count" class="form-label">Count:</label> 
                <InputNumber id="count" @bind-Value="Stock.Count" class="form-control" /> 
                <ValidationMessage For="() => Stock.Count" class="text-danger" /> 
            </div>        
            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/stocks">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm]
    private Stock Stock { get; set; } = default!;

    protected override void OnInitialized() => Stock ??= new();

    // To protect from overposting attacks, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task AddStock()
    {
        using var context = DbFactory.CreateDbContext();
        context.Stocks.Add(Stock);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/stocks");
    }
}
