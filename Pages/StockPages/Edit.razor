@page "/stocks/edit"
@using Microsoft.EntityFrameworkCore
@using LiteTe.Data
@inject IDbContextFactory<LiteTe.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>Stock</h2>
<hr />
@if (Stock is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="Stock" OnValidSubmit="UpdateStock" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="Stock.StockId" value="@Stock.StockId" />
                <div class="mb-3">
                    <label for="productid" class="form-label">ProductId:</label>
                    <InputNumber id="productid" @bind-Value="Stock.ProductId" class="form-control" />
                    <ValidationMessage For="() => Stock.ProductId" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="count" class="form-label">Count:</label>
                    <InputNumber id="count" @bind-Value="Stock.Count" class="form-control" />
                    <ValidationMessage For="() => Stock.Count" class="text-danger" />
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/stocks">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int StockId { get; set; }

    [SupplyParameterFromForm]
    private Stock? Stock { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        Stock ??= await context.Stocks.FirstOrDefaultAsync(m => m.StockId == StockId);

        if (Stock is null)
        {
            NavigationManager.NotFound();
        }
    }

    // To protect from overposting attacks, enable the specific properties you want to bind to.
    // For more information, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task UpdateStock()
    {
        using var context = DbFactory.CreateDbContext();
        context.Attach(Stock!).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!StockExists(Stock!.StockId))
            {
                NavigationManager.NotFound();
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/stocks");
    }

    private bool StockExists(int stockid)
    {
        using var context = DbFactory.CreateDbContext();
        return context.Stocks.Any(e => e.StockId == stockid);
    }
}
