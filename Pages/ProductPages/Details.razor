@page "/products/details"
@using Microsoft.EntityFrameworkCore
@using LiteTe.Data
@inject IDbContextFactory<LiteTe.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Подробности</PageTitle>

<h1>Подробности</h1>

<div>
    <h2>Товар</h2>
    <hr />
    @if (product is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Товар</dt>
            <dd class="col-sm-10">@product.ProductName</dd>
            <dt class="col-sm-2">Описание</dt>
            <dd class="col-sm-10">@product.Description</dd>
            <dt class="col-sm-2">Производитель</dt>
            <dd class="col-sm-10">@(product.Manufacturer?.ManufacturerName ?? "")</dd>
            <dt class="col-sm-2">Категория</dt>
            <dd class="col-sm-10">@(product.Category?.CategoryName ?? "")</dd>
            <dt class="col-sm-2">Поставщик</dt>
            <dd class="col-sm-10">@(product.Supplier?.SupplierName ?? "")</dd>
            <dt class="col-sm-2">Цена</dt>
            <dd class="col-sm-10">@product.Price</dd>
            <dt class="col-sm-2">Изображение</dt>
            <dd class="col-sm-10">
            <dt class="col-sm-2">Остаток на складе</dt>
            <dd class="col-sm-10">
                @{
                    var stockCount = product.Stock?.Count ?? 0;
                    if (stockCount <= 0)
                    {
                        <span class="text-danger fw-bold">Нет в наличии </span>
                    }
                    else
                    {
                        <span class="text-success fw-bold">@stockCount шт.</span>
                    }
                }
            </dd>

                @if (!string.IsNullOrEmpty(product.ProductImage))
                {
                    <img src="@product.ProductImage" alt="@product.ProductName" style="max-width: 200px; max-height: 200px;" />
                }
            </dd>
        </dl>
        <div>
            <a href="@($"/products/edit?productid={product.ProductId}&categoryid={CategoryId}")">Изменить</a> | @*тк страница продукты у нас открывается через категорию, для норм перехода потом нужно*@
            <a href="@($"/products?CategoryId={CategoryId}")">Вернуться</a> @*для перехода обратно*@
        </div>
    }
</div>

@code {
    private Product? product;

    [SupplyParameterFromQuery]
    private int ProductId { get; set; }
    [SupplyParameterFromQuery]
    public int? CategoryId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        product = await context.Products.FirstOrDefaultAsync(m => m.ProductId == ProductId);

        if (product is null)
        {
            NavigationManager.NotFound();
        }
        product = await context.Products //для вывода имен вместо ID
        .Include(p => p.Manufacturer)
        .Include(p => p.Category)
        .Include(p => p.Supplier)
        .Include(p => p.Stock)
        .FirstOrDefaultAsync(m => m.ProductId == ProductId);
    }
}
